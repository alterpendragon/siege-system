# ==========================================
# Siege System - .gitignore
# ==========================================

# Security / Environment Variables
.env

# Local Database
# We do not want to commit the actual backlog data to GitHub
*.db
*.sqlite
*.sqlite3

# Python Virtual Environments
.venv/
venv/
env/

# Python Cache & Bytecode
__pycache__/
*.py[cod]
*$py.class

# OS Generated Files
.DS_Store
Thumbs.db

# Test Coverage Reports
.coverage
